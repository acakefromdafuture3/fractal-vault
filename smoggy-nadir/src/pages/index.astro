---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fractal Vault | The Zero-Knowledge Standard">
	<main class="min-h-screen overflow-hidden bg-[#0A0E14] text-white">
		
		<nav class="flex flex-col md:flex-row justify-between items-center px-4 md:px-8 py-4 border-b border-white/5 backdrop-blur-md sticky top-0 z-50 bg-[#0A0E14]/80 gap-4 md:gap-0">
    <div class="flex items-center gap-3 w-full md:w-auto justify-center md:justify-start">
        <img 
            src="/logo.png" 
            alt="Fractal Vault Logo" 
            class="w-10 h-10 object-contain rounded-xl shadow-[0_0_15px_rgba(94,243,220,0.3)]"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="hidden w-10 h-10 bg-cyan-500 rounded-xl items-center justify-center font-bold text-black italic">FV</div>
        <span class="font-mono font-bold tracking-tighter text-xl">FRACTAL_VAULT</span>
    </div>
    
    <div class="flex w-full md:w-auto overflow-x-auto pb-2 md:pb-0 hide-scrollbar gap-6 md:gap-8 text-[10px] md:text-xs font-mono tracking-widest text-slate-500 items-center whitespace-nowrap">
        <a href="#architecture" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer uppercase">Architecture</a>
        <a href="#modules" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer uppercase">Modules</a>
        <a href="#live-demo" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer uppercase">Live_Demo</a>
        <a href="#architects" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer uppercase">Architects</a>
        
        <button id="destruct-btn" class="hover:text-red-500 text-slate-600 transition-all underline-offset-4 hover:underline cursor-pointer uppercase md:ml-4 pr-4 md:pr-0">
            Self_Destruct
        </button>
    </div>
</nav>

		<section class="relative min-h-[85vh] flex flex-col items-center justify-center px-8">
			<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');"></div>
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_center,_rgba(94,243,220,0.1)_0%,_transparent_70%)] -z-10"></div>
			
			<div class="max-w-5xl mx-auto text-center z-10 w-full">
				
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/5 text-[10px] tracking-widest uppercase text-cyan-400 mb-8">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
					</span>
					Protocol V1.0 Live
				</div>

				<h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-none mb-2 bg-clip-text text-transparent bg-gradient-to-b from-white via-white to-gray-500 drop-shadow-[0_0_30px_rgba(255,255,255,0.1)]">
					FRACTAL VAULT
				</h1>
				
				<p class="text-xl md:text-3xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-cyan-400 animate-gradient-x shadow-cyan-900/20 mb-8">
					SECURITY THROUGH PURE MATHEMATICS
				</p>

				<p class="max-w-2xl mx-auto text-gray-400 text-sm md:text-lg leading-relaxed mb-12">
					Fractal Vault decomposes your sensitive data into encrypted shards. <br class="hidden md:block" />
					No single server, person, or algorithm holds the whole key.
				</p>

				<div class="flex flex-col md:flex-row items-center justify-center gap-8">
					<a href="/fractal-vault.apk" download="FractalVault_v1.0.apk" class="group relative font-mono font-bold tracking-tighter cursor-pointer">
						<div class="absolute inset-0 bg-cyan-500 rounded-full blur-xl opacity-40 group-hover:opacity-80 transition-opacity duration-500 animate-pulse"></div>
						<div class="relative bg-white text-black text-lg md:text-xl px-10 py-4 rounded-full hover:bg-cyan-400 transition-all duration-300 shadow-[0_0_40px_rgba(94,243,220,0.4)] hover:scale-105 flex items-center gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
							</svg>
							DOWNLOAD_APK
						</div>
					</a>
					<a href="#live-demo" class="text-cyan-400 font-mono text-sm tracking-widest hover:text-white transition-colors">
						LAUNCH_VIRTUAL_PREVIEW _>
					</a>
				</div>
			</div>
		</section>

		<section id="architecture" class="py-32 px-8 bg-white/[0.01] border-y border-white/5 relative">
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-20 items-center">
				<div class="space-y-8">
					<h2 class="text-sm font-mono text-cyan-400 tracking-[0.3em] uppercase font-bold">01 // Architectural_Logic</h2>
					<h3 class="text-4xl font-bold tracking-tight">Shamir’s Secret Sharing <br/>(SSS)</h3>
					<p class="text-slate-400 leading-relaxed italic">"Never trust a single point of failure."</p>
					<p class="text-slate-400 leading-relaxed">
						We implement a <span class="text-white font-semibold">k-out-of-n threshold scheme</span>. Your vault's master key is treated as a secret mathematical constant. Without the required shards, your data remains mathematically non-existent.
					</p>
				</div>

				<div class="bg-[#05080c] p-1 rounded-2xl border border-white/10 shadow-2xl">
					<div class="bg-[#0D1117] rounded-xl p-8 font-mono text-sm leading-relaxed overflow-hidden">
						<div class="flex gap-2 mb-8">
							<div class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-yellow-500/20 border border-yellow-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-green-500/20 border border-green-500/50"></div>
						</div>
						<span class="text-cyan-500">class</span> <span class="text-yellow-400">FractalCrypt</span> {"{"} <br/>
						&nbsp;&nbsp;<span class="text-slate-500">// Sharding Protocol</span><br/>
						&nbsp;&nbsp;<span class="text-purple-400">static generateShares</span>(secret) {"{"} <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-cyan-500">const</span> k = <span class="text-orange-400">3</span>; <span class="text-slate-500">// min_threshold</span> <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-cyan-500">const</span> n = <span class="text-orange-400">5</span>; <span class="text-slate-500">// total_shards</span> <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-purple-400">return</span> split(secret, k, n);<br/>
						&nbsp;&nbsp;{"}"} <br/>
						{"}"}
					</div>
				</div>
			</div>
		</section>

		<section id="live-demo" class="py-32 px-8 bg-black relative">
			<div class="max-w-4xl mx-auto text-center mb-16">
				<h2 class="text-sm font-mono text-cyan-400 tracking-[0.3em] uppercase font-bold mb-4">02 // Live_Operation</h2>
				<h3 class="text-4xl font-bold tracking-tight">Access the Virtual Vault.</h3>
				<p class="text-slate-500 mt-4 font-mono text-xs">CLICK INSIDE THE EMULATOR TO INTERACT</p>
			</div>

			<div class="relative mx-auto border-gray-800 bg-gray-900 border-[14px] rounded-[3rem] h-[700px] w-[340px] shadow-[0_0_100px_rgba(94,243,220,0.1)] transition-transform hover:scale-[1.01]">
				<div class="w-[148px] h-[18px] bg-gray-800 top-0 left-1/2 -translate-x-1/2 rounded-b-2xl absolute z-30"></div>
				<div class="h-[46px] w-[3px] bg-gray-800 absolute -left-[17px] top-[124px] rounded-l-lg"></div>
				<div class="h-[46px] w-[3px] bg-gray-800 absolute -left-[17px] top-[178px] rounded-l-lg"></div>
				<div class="h-[64px] w-[3px] bg-gray-800 absolute -right-[17px] top-[142px] rounded-r-lg"></div>
				
				<div class="rounded-[2.2rem] overflow-hidden w-full h-full bg-[#0A0E14]">
					<iframe 
						src="https://fractal-vault-demo.web.app" 
						class="w-full h-full border-none"
						title="Fractal Vault App Preview">
					</iframe>
				</div>
			</div>
		</section>

		<section id="modules" class="py-32 px-8 border-t border-white/5">
			<div class="max-w-6xl mx-auto">
				<div class="mb-16 text-center">
					<h2 class="text-sm font-mono text-cyan-400 tracking-[0.3em] uppercase font-bold mb-4">03 // System_Modules</h2>
					<h3 class="text-4xl md:text-5xl font-bold tracking-tight">Military-Grade Arsenal.</h3>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group flex flex-col">
						<h4 class="text-xl font-bold mb-2">Core Diagnostics</h4>
						<p class="text-slate-400 text-sm mb-8">Real-time telemetry on vault health, active shards, and intercepted threats.</p>
						<div class="mt-auto h-80 py-4 rounded-xl overflow-hidden border border-white/5 bg-black/40 relative">
							<img src="/feat1.jpeg" alt="Core Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-all duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group flex flex-col">
						<h4 class="text-xl font-bold mb-2">The Encrypted Vault</h4>
						<p class="text-slate-400 text-sm mb-8">Manage shattered files, trace recent activity, and safely search encrypted records.</p>
						<div class="mt-auto h-80 py-4 rounded-xl overflow-hidden border border-white/5 bg-black/40 relative">
							<img src="/feat2.jpeg" alt="Vault Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-all duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group flex flex-col">
						<h4 class="text-xl font-bold mb-2">Radar Access Audit</h4>
						<p class="text-slate-400 text-sm mb-8">Track every authorization and threat attempt with granular IP and device logging.</p>
						<div class="mt-auto h-80 py-4 rounded-xl overflow-hidden border border-white/5 bg-black/40 relative">
							<img src="/feat3.jpeg" alt="Radar Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-all duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group flex flex-col">
						<h4 class="text-xl font-bold mb-2">System Protocols</h4>
						<p class="text-slate-400 text-sm mb-8">Configure master locks, biometric overrides, and stealth mode from the command center.</p>
						<div class="mt-auto h-80 py-4 rounded-xl overflow-hidden border border-white/5 bg-black/40 relative">
							<img src="/feat4.jpeg" alt="System Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-all duration-500" />
						</div>
					</div>
				</div>

				<div class="relative group bg-gradient-to-br from-red-900/20 to-black border border-red-500/20 rounded-3xl p-1 overflow-hidden transition-all duration-700 w-full shadow-2xl">
					<div class="bg-[#0A0E14] rounded-[22px] p-8 md:p-12 flex flex-col md:flex-row items-center gap-10">
						<div class="flex-1">
							<span class="text-red-500 font-mono text-xs tracking-[0.3em] uppercase font-bold animate-pulse">Level 5 Clearance</span>
							<h3 class="text-3xl font-bold mt-2 mb-4 text-white group-hover:text-red-400 transition-colors">The Ghost Protocol</h3>
							<p class="text-slate-400 mb-6 font-light">Advanced cloaking technology. Hover over the encrypted payload to reveal the interface.</p>
						</div>
						<div class="flex-1 w-full h-72 py-4 rounded-xl overflow-hidden border border-red-500/20 relative">
							<div class="absolute inset-0 backdrop-blur-3xl bg-[#0A0E14]/90 z-20 flex flex-col items-center justify-center group-hover:opacity-0 transition-opacity duration-700 pointer-events-none">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-red-500 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
								</svg>
								<span class="font-mono text-red-500 text-xs tracking-[0.5em]">[DATA_ENCRYPTED]</span>
							</div>
							<img src="/feat5.jpeg" alt="Secret Feature" class="zoomable cursor-pointer w-full h-full object-contain scale-110 group-hover:scale-100 transition-transform duration-700 relative z-10" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<div id="architects" class="max-w-5xl mx-auto px-4 py-24 border-t border-white/10 mt-20">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-5xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500 mb-4">
					THE ARCHITECTS
				</h2>
				<p class="text-cyan-400 font-mono text-sm tracking-widest uppercase opacity-80">
					The minds behind the mathematics
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
				
				<div class="group/card relative flex flex-col bg-[#0a0a0a] border border-white/10 rounded-3xl p-8 hover:border-cyan-500/50 hover:shadow-[0_0_30px_rgba(94,243,220,0.1)] transition-all duration-300">
					<div class="flex items-center gap-6 mb-2">
						<a href="https://github.com/acakefromdafuture3" target="_blank" class="shrink-0 w-20 h-20 md:w-24 md:h-24 rounded-full p-1 bg-gradient-to-tr from-cyan-500 to-blue-600 group-hover/card:scale-105 transition-transform duration-300 block cursor-pointer z-10">
							<img src="https://github.com/acakefromdafuture3.png" alt="Ritankar Bose" class="w-full h-full rounded-full object-cover border-4 border-[#0a0a0a]" />
						</a>
						<div>
							<h3 class="text-2xl font-bold text-white mb-1 tracking-tight">Ritankar Bose</h3>
							<p class="text-cyan-400 font-mono text-[10px] md:text-xs uppercase tracking-widest">Lead Cryptography</p>
						</div>
					</div>

					<details class="group mt-4">
						<summary class="flex items-center gap-2 cursor-pointer list-none [&::-webkit-details-marker]:hidden text-gray-500 hover:text-cyan-400 transition-colors font-mono text-xs uppercase tracking-widest select-none">
							<span>View Clearance File</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</summary>
						
						<div class="mt-4 p-5 rounded-xl bg-cyan-950/20 border border-cyan-500/30 shadow-[0_0_20px_rgba(94,243,220,0.15)] relative overflow-hidden">
							<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-50"></div>
							<p class="text-gray-300 text-sm leading-relaxed relative z-10">
								Engineered the core logic of Fractal Vault, including the implementation of the Shamir's Secret Sharing algorithm. Responsible for backend architecture, secure data fragmentation, and ensuring the system's underlying mathematics execute flawlessly across the distributed network.
							</p>
						</div>
					</details>
				</div>

				<div class="group/card relative flex flex-col bg-[#0a0a0a] border border-white/10 rounded-3xl p-8 hover:border-cyan-500/50 hover:shadow-[0_0_30px_rgba(94,243,220,0.1)] transition-all duration-300">
					<div class="flex items-center gap-6 mb-2">
						<a href="https://github.com/bloomrani" target="_blank" class="shrink-0 w-20 h-20 md:w-24 md:h-24 rounded-full p-1 bg-gradient-to-tr from-cyan-500 to-blue-600 group-hover/card:scale-105 transition-transform duration-300 block cursor-pointer z-10">
							<img src="https://github.com/bloomrani.png" alt="Rani Bhattacharjee" class="w-full h-full rounded-full object-cover border-4 border-[#0a0a0a]" />
						</a>
						<div>
							<h3 class="text-2xl font-bold text-white mb-1 tracking-tight">Rani Bhattacharjee</h3>
							<p class="text-cyan-400 font-mono text-[10px] md:text-xs uppercase tracking-widest">UI/UX & Platform Engineer</p>
						</div>
					</div>

					<details class="group mt-4">
						<summary class="flex items-center gap-2 cursor-pointer list-none [&::-webkit-details-marker]:hidden text-gray-500 hover:text-cyan-400 transition-colors font-mono text-xs uppercase tracking-widest select-none">
							<span>View Clearance File</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</summary>
						
						<div class="mt-4 p-5 rounded-xl bg-cyan-950/20 border border-cyan-500/30 shadow-[0_0_20px_rgba(94,243,220,0.15)] relative overflow-hidden">
							<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-50"></div>
							<p class="text-gray-300 text-sm leading-relaxed relative z-10">
								Designed and built the user-facing ecosystem. Focused on translating complex mathematical security into a frictionless, intuitive mobile experience. Architected the web platform, continuous deployment pipelines, and the visual identity of the Fractal Vault brand.
							</p>
						</div>
					</details>
				</div>

			</div>
		</div>

		<div id="image-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-[#05080c]/98 backdrop-blur-xl p-4 transition-opacity duration-300 opacity-0">
			<button id="close-modal" class="absolute top-6 right-6 z-[110] bg-white/10 hover:bg-white/20 text-white p-3 rounded-full transition-all border border-white/10">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<div class="relative w-full max-w-5xl flex justify-center">
				<img id="modal-img" src="" alt="Enlarged" class="max-w-full max-h-[85vh] rounded-2xl border border-white/10 shadow-2xl transition-transform duration-300 object-contain" />
			</div>
		</div>
		<button id="back-to-top" class="fixed bottom-8 right-8 z-50 bg-[#0D1117] border border-cyan-500/30 text-cyan-400 p-3 rounded-full shadow-[0_0_15px_rgba(94,243,220,0.1)] hover:bg-cyan-400 hover:text-black hover:shadow-[0_0_30px_rgba(94,243,220,0.5)] hover:scale-110 transition-all duration-500 opacity-0 translate-y-10 pointer-events-none group">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:-translate-y-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7m0 0l7 7m-7-7v18" />
			</svg>
		</button>

		<footer class="py-20 border-t border-white/5 text-center">
			<p class="font-mono text-[10px] tracking-[0.5em] text-slate-600 uppercase">Fractal Vault &copy; 2026 // Distributed Security Protocol</p>
		</footer>
	</main>
</Layout>

<script>
	// Modal Logic
	const modal = document.getElementById('image-modal');
	const modalImg = document.getElementById('modal-img') as HTMLImageElement;
	const closeBtn = document.getElementById('close-modal');
	const zoomableImgs = document.querySelectorAll('.zoomable');

	zoomableImgs.forEach(img => {
		img.addEventListener('click', (e) => {
			const target = e.target as HTMLImageElement;
			modalImg.src = target.src;
			modal?.classList.remove('hidden');
			modal?.classList.add('flex');
			setTimeout(() => {
				modal?.classList.remove('opacity-0');
				modalImg?.classList.add('scale-100');
			}, 10);
		});
	});

	const closeModal = () => {
		modal?.classList.add('opacity-0');
		modalImg?.classList.remove('scale-100');
		setTimeout(() => {
			modal?.classList.add('hidden');
			modal?.classList.remove('flex');
		}, 300);
	};

	closeBtn?.addEventListener('click', closeModal);
	modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal?.classList.contains('hidden')) closeModal(); });

	// Self Destruct Sequence
	const destructBtn = document.getElementById('destruct-btn');
	if (destructBtn) {
		destructBtn.addEventListener('click', () => {
			if(confirm("CRITICAL WARNING: Initiate Ghost Protocol Self-Destruct?")) {
				if(confirm("Are you absolutely sure? This will permanently wipe the database and burn the servers.")) {
					if(confirm("Last chance.Rani and Ritankar spent way too long building this masterpiece. Are you really going to destroy their hard work?")) {
						
						// The Screen Meltdown Animation
						document.body.style.transition = "all 2.5s ease-in-out";
						document.body.style.transform = "rotate(180deg) scale(0.01)";
						document.body.style.opacity = "0";
						document.body.style.filter = "sepia(1) hue-rotate(-50deg) saturate(500%)";
						
						setTimeout(() => {
							alert("...Just kidding! We wrote way too much code to delete it now. Reloading vault... 🚀");
							location.reload(); // Restores the page
						}, 3000);
					}
				}
			}
		});
	}
	// Back to Top Protocol Logic
	const backToTopBtn = document.getElementById('back-to-top');
	
	// Show button when scrolling down
	window.addEventListener('scroll', () => {
		if (window.scrollY > 400) {
			backToTopBtn.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
			backToTopBtn.classList.add('opacity-100', 'translate-y-0', 'cursor-pointer');
		} else {
			backToTopBtn.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
			backToTopBtn.classList.remove('opacity-100', 'translate-y-0', 'cursor-pointer');
		}
	});

	// Smooth scroll to top on click
	if (backToTopBtn) {
		backToTopBtn.addEventListener('click', () => {
			window.scrollTo({
				top: 0,
				behavior: 'smooth'
			});
		});
	}
</script>

