---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fractal Vault | The Zero-Knowledge Standard">
	<main class="min-h-screen overflow-hidden">
		
		<nav class="flex justify-between items-center px-8 py-6 border-b border-white/5 backdrop-blur-md sticky top-0 z-50 bg-[#0A0E14]/80">
			<div class="flex items-center gap-3">
				<img 
					src="/logo.png" 
					alt="Fractal Vault Logo" 
					class="w-10 h-10 object-contain rounded-xl shadow-[0_0_15px_rgba(94,243,220,0.3)]"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
				/>
				<div class="hidden w-10 h-10 bg-cyan-500 rounded-xl items-center justify-center font-bold text-black italic">FV</div>
				
				<span class="font-mono font-bold tracking-tighter text-xl">FRACTAL_VAULT</span>
			</div>
			
			<div class="hidden md:flex gap-10 text-xs font-mono tracking-widest text-slate-500">
				<a href="#architecture" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer">ARCHITECTURE</a>
				<a href="#encryption" class="hover:text-cyan-400 transition-all underline-offset-4 hover:underline cursor-pointer">ENCRYPTION</a>
			</div>
		</nav>

		<section class="relative pt-32 pb-40 px-8">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_center,_rgba(94,243,220,0.08)_0%,_transparent_70%)] -z-10"></div>
			
			<div class="max-w-5xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 px-3 py-1 border border-cyan-500/20 rounded-full bg-cyan-500/5 mb-8 animate-pulse">
					<span class="w-2 h-2 rounded-full bg-cyan-400 shadow-[0_0_8px_#5EF3DC]"></span>
					<span class="text-cyan-400 font-mono text-[10px] tracking-[0.2em] uppercase font-bold">Protocol v1.0 Live</span>
				</div>
				
				<h1 class="text-7xl md:text-[100px] font-black tracking-tighter leading-[0.9] mb-10 bg-gradient-to-b from-white via-white to-white/20 bg-clip-text text-transparent">
					Security Through <br/> Pure Mathematics.
				</h1>
				
				<p class="max-w-2xl mx-auto text-slate-400 text-lg md:text-xl font-light leading-relaxed mb-16">
					Fractal Vault decomposes your sensitive data into encrypted shards. No single server, person, or algorithm holds the whole key. 
				</p>

				<div class="mt-12 flex justify-center">
					<a href="/fractal-vault.apk" download="FractalVault_v1.0.apk" class="group relative font-mono font-bold tracking-tighter cursor-pointer">
						<div class="absolute inset-0 bg-cyan-500 rounded-full blur-xl opacity-40 group-hover:opacity-80 transition-opacity duration-500 animate-pulse"></div>
						<div class="relative bg-white text-black text-lg md:text-2xl px-12 py-5 rounded-full hover:bg-cyan-400 transition-all duration-300 shadow-[0_0_40px_rgba(94,243,220,0.4)] hover:scale-105 flex items-center gap-4">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
							</svg>
							DOWNLOAD_APK
						</div>
					</a>
				</div>
			</div>
		</section>

		<section id="architecture" class="py-32 px-8 bg-white/[0.01] border-y border-white/5 relative">
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-20 items-center">
				<div class="space-y-8">
					<h2 class="text-sm font-mono text-cyan-400 tracking-[0.3em] uppercase font-bold">01 // Architectural_Logic</h2>
					<h3 class="text-4xl font-bold tracking-tight">Shamir’s Secret Sharing <br/>(SSS)</h3>
					<p class="text-slate-400 leading-relaxed italic">
						"Never trust a single point of failure." 
					</p>
					<p class="text-slate-400 leading-relaxed">
						We implement a <span class="text-white">k-out-of-n threshold scheme</span>. Your vault's master key is treated as the constant term in a random polynomial. Without the required shards, the data is mathematically non-existent.
					</p>
				</div>

				<div class="bg-[#05080c] p-1 rounded-2xl border border-white/10 shadow-2xl">
					<div class="bg-[#0D1117] rounded-xl p-8 font-mono text-sm leading-relaxed overflow-hidden">
						<div class="flex gap-2 mb-8">
							<div class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-yellow-500/20 border border-yellow-500/50"></div>
							<div class="w-3 h-3 rounded-full bg-green-500/20 border border-green-500/50"></div>
						</div>
						<span class="text-cyan-500">class</span> <span class="text-yellow-400">FractalCrypt</span> {"{"} <br/>
						&nbsp;&nbsp;<span class="text-slate-500">// Threshold Logic</span><br/>
						&nbsp;&nbsp;<span class="text-purple-400">static generateShares</span>(secret) {"{"} <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-cyan-500">const</span> k = <span class="text-orange-400">3</span>; <span class="text-slate-500">// min shares</span> <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-cyan-500">const</span> n = <span class="text-orange-400">5</span>; <span class="text-slate-500">// total shares</span> <br/>
						&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-purple-400">return</span> split(secret, k, n);<br/>
						&nbsp;&nbsp;{"}"} <br/>
						{"}"}
					</div>
				</div>
			</div>
		</section>

		<section id="encryption" class="py-32 px-8 border-t border-white/5 w-full">
			<div class="max-w-6xl mx-auto w-full">
				<div class="mb-16 text-center">
					<h2 class="text-sm font-mono text-cyan-400 tracking-[0.3em] uppercase font-bold mb-4">System_Modules</h2>
					<h3 class="text-4xl md:text-5xl font-bold tracking-tight">Military-Grade Arsenal.</h3>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 w-full">
					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group overflow-hidden flex flex-col w-full">
						<h4 class="text-xl font-bold mb-2">Core Diagnostics</h4>
						<p class="text-slate-400 text-sm mb-8">Real-time telemetry on vault health, active shards, and intercepted threats.</p>
						<div class="mt-auto h-72 py-4 rounded-xl overflow-hidden border border-white/5 bg-black relative">
							<img src="/feat1.jpeg" alt="Core Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-opacity duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group overflow-hidden flex flex-col w-full">
						<h4 class="text-xl font-bold mb-2">The Encrypted Vault</h4>
						<p class="text-slate-400 text-sm mb-8">Manage shattered files, trace recent activity, and safely search encrypted records.</p>
						<div class="mt-auto h-72 py-4 rounded-xl overflow-hidden border border-white/5 bg-black relative">
							<img src="/feat2.jpeg" alt="Vault Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-opacity duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group overflow-hidden flex flex-col w-full">
						<h4 class="text-xl font-bold mb-2">Radar Access Audit</h4>
						<p class="text-slate-400 text-sm mb-8">Track every authorization and threat attempt with granular IP and device logging.</p>
						<div class="mt-auto h-72 py-4 rounded-xl overflow-hidden border border-white/5 bg-black relative">
							<img src="/feat3.jpeg" alt="Radar Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-opacity duration-500" />
						</div>
					</div>

					<div class="bg-[#0D1117] border border-white/5 rounded-3xl p-8 hover:border-cyan-500/30 transition-all group overflow-hidden flex flex-col w-full">
						<h4 class="text-xl font-bold mb-2">System Protocols</h4>
						<p class="text-slate-400 text-sm mb-8">Configure master locks, biometric overrides, and stealth mode from the command center.</p>
						<div class="mt-auto h-72 py-4 rounded-xl overflow-hidden border border-white/5 bg-black relative">
							<img src="/feat4.jpeg" alt="System Screen" class="zoomable cursor-pointer w-full h-full object-contain opacity-60 group-hover:opacity-100 transition-opacity duration-500" />
						</div>
					</div>
				</div>

				<div class="relative group bg-gradient-to-br from-red-900/20 to-black border border-red-500/20 rounded-3xl p-1 overflow-hidden shadow-[0_0_30px_rgba(239,68,68,0.05)] hover:shadow-[0_0_50px_rgba(239,68,68,0.15)] transition-all duration-700 w-full">
					<div class="bg-[#0A0E14] rounded-[22px] p-8 md:p-12 flex flex-col md:flex-row items-center gap-10">
						<div class="flex-1">
							<span class="text-red-500 font-mono text-xs tracking-[0.3em] uppercase font-bold animate-pulse">Level 5 Clearance</span>
							<h3 class="text-3xl font-bold mt-2 mb-4 text-white group-hover:text-red-400 transition-colors">The Ghost Protocol</h3>
							<p class="text-slate-400 mb-6">A feature so powerful we keep it hidden. Hover over the encrypted payload to reveal the interface.</p>
						</div>
						<div class="flex-1 w-full h-72 py-4 rounded-xl overflow-hidden border border-red-500/20 relative">
							<div class="absolute inset-0 backdrop-blur-xl bg-[#0A0E14]/80 z-20 flex flex-col items-center justify-center group-hover:opacity-0 transition-opacity duration-700 pointer-events-none">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
								</svg>
								<span class="font-mono text-red-500 text-xs tracking-[0.4em]">[ENCRYPTED_PAYLOAD]</span>
							</div>
							<img src="/feat5.jpeg" alt="Secret Feature" class="zoomable cursor-pointer w-full h-full object-contain scale-110 group-hover:scale-100 transition-transform duration-700 relative z-10" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<div id="image-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-[#05080c]/98 backdrop-blur-xl p-4 transition-opacity duration-300 opacity-0">
			
			<button id="close-modal" class="absolute top-4 right-4 z-[110] bg-white/10 hover:bg-white/20 text-white p-2 rounded-full transition-all border border-white/10">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>

			<div class="relative w-full max-w-4xl flex justify-center items-center">
				<img id="modal-img" src="" alt="Enlarged view" class="max-w-full max-h-[80vh] md:max-h-[90vh] rounded-2xl border border-white/10 shadow-[0_0_80px_rgba(94,243,220,0.15)] transform scale-95 transition-transform duration-300 object-contain" />
			</div>
		</div>
	</main>
</Layout>

<script>
	const modal = document.getElementById('image-modal');
	const modalImg = document.getElementById('modal-img') as HTMLImageElement;
	const closeBtn = document.getElementById('close-modal');
	const zoomableImgs = document.querySelectorAll('.zoomable');

	zoomableImgs.forEach(img => {
		img.addEventListener('click', (e) => {
			const target = e.target as HTMLImageElement;
			modalImg.src = target.src;
			modal?.classList.remove('hidden');
			modal?.classList.add('flex');
			setTimeout(() => {
				modal?.classList.remove('opacity-0');
				modalImg?.classList.remove('scale-95');
				modalImg?.classList.add('scale-100');
			}, 10);
		});
	});

	const closeModal = () => {
		modal?.classList.add('opacity-0');
		modalImg?.classList.remove('scale-100');
		modalImg?.classList.add('scale-95');
		setTimeout(() => {
			modal?.classList.add('hidden');
			modal?.classList.remove('flex');
		}, 300);
	};

	closeBtn?.addEventListener('click', closeModal);
	modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal?.classList.contains('hidden')) closeModal(); });
</script>